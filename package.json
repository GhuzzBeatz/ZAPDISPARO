{
  "name": "zapdisparo",
  "version": "1.0.14",
  "description": "ZapDisparo - Disparador de Mensagens em Massa para WhatsApp",
  "main": "main.js",
  "author": "GHZ Plugin",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "ci:bump-version": "npm version patch --no-git-tag-version",
    "ci:write-manifest": "node scripts/write-update-manifest.js"
  },
  "build": {
    "appId": "com.ghzplugin.zapdisparo",
    "productName": "ZapDisparo",
    "directories": {
      "output": "dist_installer"
    },
    "files": [
      "**/*",
      "!dist_installer/**",
      "!_work/**",
      "!*.zip",
      "!**/*.zip",
      "!node_modules/.cache/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ZapDisparo"
    },
    "asarUnpack": [
      "node_modules/puppeteer/.local-chromium/**",
      "node_modules/puppeteer-core/.local-chromium/**",
      "node_modules/@puppeteer/browsers/**",
      "node_modules/puppeteer/**/*.node",
      "node_modules/whatsapp-web.js/**"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "qrcode": "^1.5.3",
    "whatsapp-web.js": "^1.34.7",
    "xlsx": "^0.18.5"
  }
}
